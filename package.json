{
  "name": "guardian-academy",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:mobile": "cd apps/mobile && npm start",
    "dev:scoring": "cd packages/scoring-engine && npm run dev",
    "dev:audit": "cd packages/audit-logger && npm run dev",
    "dev:all": "concurrently \"npm run dev:web\" \"npm run dev:mobile\" \"npm run dev:scoring\" \"npm run dev:audit\"",
    "build:web": "cd apps/web && npm run build",
    "build:mobile": "cd apps/mobile && npm run build",
    "build:scoring": "cd packages/scoring-engine && npm run build",
    "build:audit": "cd packages/audit-logger && npm run build",
    "build:all": "concurrently \"npm run build:web\" \"npm run build:mobile\" \"npm run build:scoring\" \"npm run build:audit\"",
    "test:web": "cd apps/web && npm test",
    "test:mobile": "cd apps/mobile && npm test",
    "test:scoring": "cd packages/scoring-engine && npm test",
    "test:audit": "cd packages/audit-logger && npm test",
    "test:all": "concurrently \"npm run test:web\" \"npm run test:mobile\" \"npm run test:scoring\" \"npm run test:audit\""
  },
  "dependencies": {
    "concurrently": "^8.2.0",
    "bcryptjs": "^2.4.3",
    "expo": "^49.0.0",
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "next": "^16.1.6"
  },
  "devDependencies": {
    "tailwindcss": "^4.0.0",
    "postcss": "^8.4.26",
    "autoprefixer": "^10.4.15",
    "@tailwindcss/postcss": "^4.0.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
